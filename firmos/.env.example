# FirmOS environment (all optional in demo mode — the app runs with the local
# JSON demo tenant when Supabase vars are absent).

# Production data layer (Supabase project) — schema in supabase/migrations/
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Notification channels — until set, notifications remain visibly "queued".
SMS_GATEWAY_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Payments (PayFast / Kuickpay sandbox or live)
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=

# AI receptionist LLM (optional — deterministic intake flow works without it)
ANTHROPIC_API_KEY=
