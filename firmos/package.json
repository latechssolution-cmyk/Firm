{
  "name": "firmos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:contrast && npm run check:hex && next build",
    "start": "next start",
    "lint": "next lint",
    "check:contrast": "node scripts/check-contrast.mjs",
    "check:hex": "node scripts/check-hex.mjs",
    "test": "node --import tsx --test tests/seed.test.ts",
    "test:e2e": "node --test tests/e2e.test.mjs",
    "test:all": "npm run check:contrast && npm run check:hex && npm test && npm run test:e2e"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
